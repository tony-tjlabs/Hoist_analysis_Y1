# Streamlit Cloud / AWS EC2 Secrets Template
# Copy this to .streamlit/secrets.toml (local) or paste in Streamlit Cloud Settings

# Required: Cloud mode setting
CLOUD_MODE = "true"

# Required: App password
APP_PASSWORD = "your_password_here"

# Optional: LLM Integration (Claude API for insights)
# If not set, LLM sections will be hidden gracefully
# ANTHROPIC_API_KEY = "sk-ant-api03-xxxx"
